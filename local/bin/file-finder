#!/bin/bash

# File finder with fzf that opens files in nvim
# Save this as ~/.local/bin/file-finder (or any name you prefer)
# Make it executable: chmod +x ~/.local/bin/file-finder

# Configuration
SEARCH_DIR="${1:-.}"  # Use provided directory or current directory
PREVIEW_CMD="cat {}"  # Simple preview, or use 'bat' if installed

# Check if fzf is installed
if ! command -v fzf &> /dev/null; then
    echo "Error: fzf is not installed"
    echo "Install with: sudo apt install fzf  # or your package manager"
    exit 1
fi

# Find and select file with fzf
selected_file=$(find "$SEARCH_DIR" -type f \
    -not -path "*/\.*" \
    -not -path "*/node_modules/*" \
    -not -path "*/.git/*" \
    -not -path "*/venv/*" \
    -not -path "*/__pycache__/*" \
    2>/dev/null | \
    fzf --height=80% \
        --layout=reverse \
        --border \
        --prompt="Open file: " \
        --preview="$PREVIEW_CMD" \
        --preview-window=right:50%:wrap \
        --bind='ctrl-/:toggle-preview' \
        --header='CTRL-/ to toggle preview | ESC to cancel')

# Open selected file in nvim if a file was selected
if [ -n "$selected_file" ]; then
    nvim "$selected_file"
fi
