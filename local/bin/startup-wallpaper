#!/usr/bin/env bash

wallDir=~/.config/cosmic/walls

indexFile=~/.config/cosmic/wallIndex
touch $indexFile
wallIndex=$(cat ~/.config/cosmic/wallIndex)

mapfile array < <(ls $wallDir)

arrayLength=${#array[@]}

if ((((wallIndex + 1)) >= arrayLength)); then
  echo 0 >$indexFile
fi

swaybg -i "$wallDir""/"${array[$((wallIndex))]} &
