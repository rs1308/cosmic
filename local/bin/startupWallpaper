#!/usr/bin/env bash

currentTheme=$(cat ~/.config/cosmic/current-theme)

baseWallDir=~/.config/cosmic/walls

wallDir="$baseWallDir""/""$currentTheme"

indexDir=~/.config/cosmic/walls/indices
indexFile="$indexDir""/""$currentTheme"

wallIndex=$(cat $indexFile)

mapfile array < <(ls $wallDir)

arrayLength=${#array[@]}

if ((((wallIndex + 1)) >= arrayLength)); then
  echo 0 >$indexFile
fi

swaybg -i "$wallDir""/"${array[$((wallIndex))]} &
