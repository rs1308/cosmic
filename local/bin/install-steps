#!/usr/bin/env bash

echo "Updating Packages"

sudo pacman -Syuu git base-devel

echo "Installing yay"

git clone https://aur.archlinux.org/yay.git

cd yay

makepkg -si

rm -rf yay

echo "Installing necessary packages"

yay -S grim slurp waybar alacritty-sixel-git neovim rofi maple-mono-nf-cn-unhinted zsh zsh-autosuggestions zsh-syntax-highlighting zoxide zenity yazi xdg-desktop-portal-hyprland brightnessctl swaybg pavucontrol mpd mpc ncmpcpp impala bluetui bluez bluez-utils bibata-cursor-theme --noconfirm

echo "About to install lazyvim"

git clone https://github.com/LazyVim/starter ~/.config/nvim

rm -rf ~/.config/nvim/.git

echo "Setting up symlinks"

rm -rf ~/.config/hypr

ln -sf ~/.config/cosmic/config/hypr ~/.config/

rm -rf ~/.config/waybar

ln -sf ~/.config/cosmic/config/waybar ~/.config/

rm -rf ~/.config/dunst

ln -sf ~/.config/cosmic/config/dunst ~/.config/

ln -sf ~/.config/cosmic/local/bin ~/.local/

rm -rf ~/.config/alacritty

ln -sf ~/.config/cosmic/config/alacritty ~/.config

rm -rf ~/.config/starship.toml

ln -sf ~/.config/cosmic/config/starship.toml ~/.config/

rm -rf ~/.config/rofi

ln -sf ~/.config/cosmic/config/rofi ~/.config/

rm -rf ~/.config/zathura

ln -sf ~/.config/cosmic/config/zathura ~/.config/
