#!/usr/bin/env bash

wallDir=~/.config/cosmic/walls

indexFile=~/.config/cosmic/wallIndex
touch $indexFile
wallIndex=$(cat ~/.config/cosmic/wallIndex)

mapfile array < <(ls $wallDir)

arrayLength=${#array[@]}

if ((((wallIndex + 1)) < arrayLength)); then
  echo $((wallIndex + 1)) >$indexFile
  toBeApplied=$((wallIndex + 1))
else
  echo 0 >$indexFile
  toBeApplied=0
fi

killall swaybg
swaybg -i "$wallDir""/"${array[$toBeApplied]} &
