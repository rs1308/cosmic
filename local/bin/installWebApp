#!/usr/bin/env bash

name=$(gum input --placeholder "Enter name of App")

[[ -z "$name" ]] && echo "Error: Name cannot be empty." && sleep 2 && exit 1

url=$(gum input --placeholder "Enter url for the website (eg.https://example.com)")

[[ -z "$name" ]] && echo "Error: Name cannot be empty." && sleep 2 && exit 1

browser=$(gum input --placeholder "Enter browser that you want to use (chromium based)")

iconUrl=$(gum input --placeholder "Enter svg url for App from dashboardicons.com")

homeDir=$(echo $HOME)

iconpath="$homeDir/.local/share/icons/$name.svg"

curl -L -o ~/.local/share/icons/$name.svg "$iconUrl"

launchCommand="$browser --app=\""$url"\" --user-data-dir=\""$homeDir"/.config/webApps/"$name"\" --no-first-run --no-default-browser-check"

cat >~/.local/share/applications/$name.desktop <<EOF
[Desktop Entry]
Type=Application
Name=$name
Exec=$launchCommand
Icon=$homeDir/.local/share/icons/$name.svg
Terminal=false
EOF
